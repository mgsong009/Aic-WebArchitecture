# Copy this file to .env and replace every value before deploying.
# Do not commit the real .env file.

MYSQL_ROOT_PASSWORD=replace-with-random-root-password
MYSQL_PASSWORD=replace-with-random-app-password

# Must be at least 32 characters and must not contain placeholder/default text.
# The sample value is intentionally invalid so deployments fail until it is replaced.
JWT_SECRET=change_this_to_a_32_plus_character_random_secret

# Email used by Caddy for ACME/ZeroSSL certificate issuance.
ACME_EMAIL=admin@example.com
